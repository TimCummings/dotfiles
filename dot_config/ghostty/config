font-family = "Intel One Mono"
font-feature = -calt
font-feature = -dlig
font-feature = -liga
theme = ChallengerDeep

custom-shader = ./shaders/cursor_smear.glsl

keybind = ctrl+escape>r=reload_config
keybind = ctrl+shift+page_up=scroll_page_up
keybind = ctrl+shift+page_down=scroll_page_down
keybind = ctrl+shift+{=jump_to_prompt:-1
keybind = ctrl+shift+}=jump_to_prompt:1
# keybind = ctrl+escape>u=write_screen_file:open

# SPLITS
#   unbind default `new_split:right`
keybind = ctrl+shift+o=unbind
keybind = ctrl+escape>v=new_split:right
keybind = ctrl+escape>x=new_split:down
keybind = ctrl+escape>h=goto_split:left
# keybind = alt+h=goto_split:left
keybind = ctrl+escape>j=goto_split:bottom
# keybind = alt+j=goto_split:bottom
keybind = ctrl+escape>k=goto_split:top
# keybind = alt+k=goto_split:top
keybind = ctrl+escape>l=goto_split:right
# keybind = alt+l=goto_split:right
keybind = ctrl+escape>c=close_surface
keybind = ctrl+escape>z=toggle_split_zoom
keybind = ctrl+escape>space=equalize_splits
keybind = ctrl+escape>shift+,=resize_split:left,10
keybind = ctrl+escape>shift+.=resize_split:right,10
keybind = ctrl+escape>plus=resize_split:up,10
keybind = ctrl+escape>-=resize_split:down,10

# TABS
keybind = ctrl+escape>p=previous_tab
keybind = ctrl+escape>n=next_tab
keybind = ctrl+escape>t=new_tab
# only works with libadwaita currently
keybind = ctrl+escape>w=toggle_tab_overview
keybind = ctrl+escape>,=prompt_surface_title

# Vim-mode keybindings for Ghostty.
#
# Note: We're missing a number of actions to produce a better vim experience.
# This is what is possible today! But we plan on adding more actions to make
# this even better in the future.

# Entry point
keybind = ctrl+escape>u=activate_key_table:vim

# Key table definition
keybind = vim/

# Line movement
keybind = vim/j=scroll_page_lines:1
keybind = vim/k=scroll_page_lines:-1

# Page movement
keybind = vim/ctrl+d=scroll_page_down
keybind = vim/ctrl+u=scroll_page_up
keybind = vim/ctrl+f=scroll_page_down
keybind = vim/ctrl+b=scroll_page_up
keybind = vim/shift+j=scroll_page_down
keybind = vim/shift+k=scroll_page_up

# Jump to top/bottom
keybind = vim/g>g=scroll_to_top
keybind = vim/shift+g=scroll_to_bottom

# Search (if you want vim-style search entry)
keybind = vim/slash=start_search
keybind = vim/n=navigate_search:next

# Copy mode / selection
# Note we're missing a lot of actions here to make this more full featured.
keybind = vim/v=copy_to_clipboard
keybind = vim/y=copy_to_clipboard

# Command Palette
keybind = vim/shift+semicolon=toggle_command_palette

# Exit
keybind = vim/escape=deactivate_key_table
keybind = vim/q=deactivate_key_table
keybind = vim/i=deactivate_key_table

# Catch unbound keys
keybind = vim/catch_all=ignore
